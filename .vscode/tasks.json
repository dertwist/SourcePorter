{
  "version": "2.0.0",
  "options": {
    "cwd": "${workspaceFolder}"
  },
  "tasks": [
    {
      "label": "build",
      "detail": "dotnet build the full solution (Debug)",
      "command": "dotnet",
      "type": "process",
      "args": [
        "build",
        "${workspaceFolder}/SourcePorter.sln",
        "-c",
        "Debug",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary;ForceNoAlign"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "silent",
        "clear": true
      },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "rebuild",
      "detail": "Clean then build (Debug)",
      "command": "dotnet",
      "type": "process",
      "args": [
        "build",
        "${workspaceFolder}/SourcePorter.sln",
        "-c",
        "Debug",
        "--no-incremental",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary"
      ],
      "group": "build",
      "problemMatcher": "$msCompile"
    },
    {
      "label": "clean",
      "detail": "Remove build output",
      "command": "dotnet",
      "type": "process",
      "args": ["clean", "${workspaceFolder}/SourcePorter.sln"],
      "problemMatcher": "$msCompile"
    },
    {
      "label": "run",
      "detail": "Build and run the WinForms app",
      "command": "dotnet",
      "type": "process",
      "args": [
        "run",
        "--project",
        "${workspaceFolder}/src/SourcePorter.App/SourcePorter.App.csproj"
      ],
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "test",
      "detail": "Run the unit tests",
      "command": "dotnet",
      "type": "process",
      "args": ["test", "${workspaceFolder}/SourcePorter.sln"],
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "publish",
      "detail": "Single portable exe — self-contained win-x64 Release build",
      "command": "dotnet",
      "type": "process",
      "args": [
        "publish",
        "${workspaceFolder}/src/SourcePorter.App/SourcePorter.App.csproj",
        "-c",
        "Release",
        "-r",
        "win-x64",
        "--self-contained",
        "true",
        "-p:PublishSingleFile=true",
        "-p:IncludeNativeLibrariesForSelfExtract=true",
        "-p:DebugType=embedded",
        "-o",
        "${workspaceFolder}/artifacts/publish"
      ],
      "problemMatcher": "$msCompile"
    }
  ]
}
